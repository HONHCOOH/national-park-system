{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "启动后端 (FastAPI)",
            "type": "shell",
            "command": "python",
            "args": ["run.py"],
            "options": {
                "cwd": "${workspaceFolder}/backend"
            },
            "group": "none",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "group": "backend"
            },
            "problemMatcher": []
        },
        {
            "label": "启动前端 (Vite)",
            "type": "shell",
            "command": "npm",
            "args": ["run", "dev"],
            "options": {
                "cwd": "${workspaceFolder}/frontend"
            },
            "group": "none",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "group": "frontend"
            },
            "problemMatcher": []
        },
        {
            "label": "一键启动全部服务",
            "dependsOn": [
                "启动后端 (FastAPI)",
                "启动前端 (Vite)"
            ],
            "dependsOrder": "parallel",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        }
    ]
}
